View(nc_sc_trees)
# Use str_match to extract the genus from the Scientific Name
nc_sc_trees = mutate(nc_sc_trees, genus = str_match(ScientificName, "^([:alpha:]+)")[,2])
# Compute average crown diameter by genus
genus_canopy = nc_sc_trees |>
group_by(genus) |>
summarize(
Avg_Crown_Diameter_m = mean(`AvgCdia (m)`, na.rm = TRUE),
Sample_Size = n()
) |>
arrange(desc(Avg_Crown_Diameter_m))
head(genus_canopy)
View(genus_canopy)

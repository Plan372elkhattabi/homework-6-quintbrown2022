library(tidyverse)
data <- read_csv("Data/TS3_Raw_tree_data.csv")
View(data)
# Use str_match to create separate columns for city and state based on capturing groups
tree_data[,c("city_name", "state_abbrev")] = str_match(tree_data$City, "^(.*),[:space:]*([:alpha:]+)$")[,2:3]
# Use str_match to create separate columns for city and state based on capturing groups
data[,c("city_name", "state_abbrev")] = str_match(data$City, "^(.*),[:space:]*([:alpha:]+)$")[,2:3]
# Table of records in each state
state_counts = data |>
group_by(state_abbrev) |>
summarize(Records = n()) |>
arrange(desc(Records))
knitr::kable(state_counts, caption = "Number of Tree Records by State")
# Bar plot of records by state
ggplot(state_counts, aes(x = reorder(state_abbrev, -Records), y = Records)) +
geom_bar(stat = "identity", fill = "steelblue") +
theme_minimal() +
labs(
title = "Tree Records by State",
x = "State",
y = "Number of Records"
)
